FROM cgr.dev/chainguard/static@sha256:2fdfacc8d61164aa9e20909dceec7cc28b9feb66580e8e1a65b9f2443c53b61b
COPY assets /assets
COPY openfga /

# Goreleaser does not support multi-stage builds. See:
# https://github.com/goreleaser/goreleaser/issues/609
#
# Dependabot is also not capable of updating inline image copies at this time, so
# this needs to be updated manually until one of these issues is resolved.
COPY --from=ghcr.io/grpc-ecosystem/grpc-health-probe:v0.4.47@sha256:c96d67e1e2f55c61d152bb1230ad4e2fbe56345d07bc45e789f2712f284ccc31 /ko-app/grpc-health-probe /usr/local/bin/grpc_health_probe
ENTRYPOINT ["/openfga"]
